{
  "name": "ranvier-vscode",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.0.6",
  "publisher": "cellaxon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ranvier-rs/vscode.git"
  },
  "homepage": "https://github.com/ranvier-rs/vscode",
  "bugs": {
    "url": "https://github.com/ranvier-rs/vscode/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "main": "./dist/extension.js",
  "icon": "media/favicon.png",
  "activationEvents": [
    "onCommand:ranvier.openCircuitView",
    "onCommand:ranvier.refreshDiagnostics",
    "onCommand:ranvier.revealNodeFromCurrentLine",
    "onCommand:ranvier.nextNodeIssue",
    "onCommand:ranvier.previousNodeIssue",
    "onView:ranvierCircuitNodes"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ranvier",
          "title": "%viewsContainer.ranvier.title%",
          "icon": "media/activitybar-ranvier.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "ranvier.openCircuitView",
        "title": "%command.openCircuitView.title%"
      },
      {
        "command": "ranvier.refreshCircuitData",
        "title": "%command.refreshCircuitData.title%"
      },
      {
        "command": "ranvier.exportSchematic",
        "title": "%command.exportSchematic.title%"
      },
      {
        "command": "ranvier.revealNodeSource",
        "title": "%command.revealNodeSource.title%"
      },
      {
        "command": "ranvier.refreshDiagnostics",
        "title": "%command.refreshDiagnostics.title%"
      },
      {
        "command": "ranvier.revealNodeFromCurrentLine",
        "title": "%command.revealNodeFromCurrentLine.title%"
      },
      {
        "command": "ranvier.nextNodeIssue",
        "title": "%command.nextNodeIssue.title%"
      },
      {
        "command": "ranvier.previousNodeIssue",
        "title": "%command.previousNodeIssue.title%"
      }
    ],
    "views": {
      "ranvier": [
        {
          "id": "ranvierCircuitNodes",
          "name": "%view.ranvierCircuitNodes.name%",
          "type": "webview"
        },
        {
          "id": "ranvierToolbox",
          "name": "Template Toolbox",
          "type": "webview"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ranvier.nextNodeIssue",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "ranvier.previousNodeIssue",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p",
        "when": "editorTextFocus && !editorReadonly"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "ranvier.schematicExport.example": {
          "type": "string",
          "default": "basic-schematic",
          "description": "%configuration.schematicExport.example.description%"
        },
        "ranvier.schematicExport.outputPath": {
          "type": "string",
          "default": "schematic.json",
          "description": "%configuration.schematicExport.outputPath.description%"
        },
        "ranvier.diagnostics.inputPath": {
          "type": "string",
          "default": "diagnostics.json",
          "description": "%configuration.diagnostics.inputPath.description%"
        }
      }
    }
  },
  "keywords": [
    "ranvier",
    "circuit",
    "schematic",
    "svelteflow",
    "visualization",
    "decision-engine"
  ],
  "galleryBanner": {
    "color": "#1e2c43",
    "theme": "dark"
  },
  "preview": true,
  "badges": [],
  "markdown": "github",
  "qna": "marketplace",
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && npm run build:webview && npm run build:extension",
    "build:webview": "vite build",
    "build:extension": "node esbuild.mjs",
    "package": "npm run build && vsce package",
    "release:verify": "node ./scripts/release-verify.mjs",
    "release:verify:docs": "node ./scripts/release-verify-docs.mjs",
    "publish:marketplace": "npm run build && vsce publish",
    "watch:webview": "vite build --watch",
    "watch:extension": "node esbuild.mjs --watch",
    "dev": "concurrently \"npm:watch:webview\" \"npm:watch:extension\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "perf:schematic": "node --import tsx ./scripts/perf-schematic.ts"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.6.2",
    "concurrently": "^9.1.0",
    "esbuild": "^0.24.0",
    "rimraf": "^6.0.1",
    "svelte": "^5.14.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "dependencies": {
    "@xyflow/svelte": "^1.5.0",
    "vscode-nls": "^5.2.0",
    "zod": "^4.3.6"
  }
}